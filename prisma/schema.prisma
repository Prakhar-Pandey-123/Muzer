generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}
datasource db {
  provider = "postgresql"
}

model User{
  id         String     @id  @default(uuid())
  email      String     @unique
  provider   Provider
  streams    Stream[]
  upvotes    Upvote[]
}
enum Provider{
  Google
}
//every user entity has one id,one email,one provider and a bunch of streams coz its an array[],and then he can have bunch of upvotes too 

model Stream{
  id               String      @id  @default(uuid())
  type             StreamType
  url              String
  extractedID      String
  title            String
  smallImg         String
  bigImg           String
  active           Boolean     @default(true)
  userId           String
  user             User        @relation(fields: [userId], references: [id])
  upvotes          Upvote[]
}
enum StreamType{
  Spotify
  Youtube
}
// now every stream has one id , type,and a userid which is type string, now = User        @relation(fields: [userId], references: [id]) ,this means we connecting this field to User table and which field ?-fields:userId and reference to which field of User table ? -id

model Upvote{
  id          String      @id  @default(uuid())
  userId      String      
  streamId    String
  user        User        @relation(fields: [userId],references: [id])
  stream      Stream      @relation(fields: [streamId],references: [id])
  @@unique([userId,streamId])
}


